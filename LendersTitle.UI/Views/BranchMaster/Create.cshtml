@model LendersTitle.UI.Models.BranchMasterModel.BranchMaster
@{
    ViewData["Title"] = "Create Branch";
}

<div class="page-header">
    <div class="page-header__breadcrumb">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span class="page-header__breadcrumb-sep">/</span>
        <a asp-action="Index">Branch Management</a>
        <span class="page-header__breadcrumb-sep">/</span>
        <span class="page-header__breadcrumb-current">Create Branch</span>
    </div>
</div>

<div class="page-title">Create Branch</div>
<div class="page-subtitle">Add a new branch to the system</div>

<form asp-action="Create" method="post" class="content-section" id="createBranchForm" novalidate>
    <div class="content-section__header">
        <div class="content-section__title">Branch Details</div>
    </div>

    <div class="content-section__body">
        <div class="form-row">
            <div class="form-group flex-1">
                <label asp-for="BranchName" class="form-label form-label--required"></label>
                <input asp-for="BranchName"
                       class="form-control"
                       placeholder="Enter branch name"
                       autocomplete="off"
                       required />
                <span asp-validation-for="BranchName" class="invalid-feedback"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label class="form-label">Status</label>
                <div class="d-flex align-items-center gap-3">
                    <div class="form-check form-switch mb-0">
                        <input asp-for="IsActive"
                               class="form-check-input"
                               role="switch"
                               id="IsActive" />
                        <label class="form-check-label" for="IsActive">
                            @(Model.IsActive ? "Active" : "Inactive")
                        </label>
                    </div>
                </div>
                <div class="form-text">Toggle to activate or deactivate this branch</div>
            </div>
        </div>
    </div>

    <div class="form-actions form-actions--between">
        <a asp-action="Index" class="btn btn-ghost">
            <i class="fa-solid fa-arrow-left"></i>
            <span>Cancel</span>
        </a>
        <button type="submit" class="btn btn-primary btn-icon-text" id="submitBtn">
            <i class="fa-solid fa-building"></i>
            <span class="btn-text">Create Branch</span>
            <span class="btn-spinner" style="display:none;"></span>
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function ($) {
            var $form = $('#createBranchForm');
            var $submitBtn = $('#submitBtn');
            var $btnText = $submitBtn.find('.btn-text');
            var $btnSpinner = $submitBtn.find('.btn-spinner');
            var $isActive = $('#IsActive');
            var $isActiveLabel = $isActive.closest('.form-switch').find('.form-check-label');

            $isActive.on('change', function () {
                $isActiveLabel.text(this.checked ? 'Active' : 'Inactive');
            });

            $form.on('submit', function () {
                $submitBtn.prop('disabled', true);
                $submitBtn.addClass('btn--loading');
                $btnText.css('opacity', '0');
                $btnSpinner.show();
            });

            $('input').on('invalid', function (e) {
                var $target = $(e.target);
                $target.addClass('is-invalid');
                var $feedback = $target.siblings('.invalid-feedback');
                if ($feedback.length && !$target[0].validationMessage) {
                    $feedback.show();
                }
            });

            $('input').on('input', function () {
                var $target = $(this);
                if ($target.hasClass('is-invalid')) {
                    $target.removeClass('is-invalid');
                    $target.siblings('.invalid-feedback').hide();
                }
            });

        })(jQuery);
    </script>
}
