@model LendersTitle.UI.Models.BranchMasterModel.BranchListViewModel
@{
    ViewData["Title"] = "Branch Management";
}

<div class="page-header">
    <div class="page-header__breadcrumb">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span class="page-header__breadcrumb-sep">/</span>
        <span class="page-header__breadcrumb-current">Branch Management</span>
    </div>
    <div class="page-header__actions">
        <a asp-action="Create" class="btn btn-primary btn-icon-text">
            <i class="fa-solid fa-plus"></i>
            <span>Create New Branch</span>
        </a>
    </div>
</div>

<div class="page-title">Branch Management</div>
<div class="page-subtitle">Manage all registered branches and their status</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success d-flex align-items-center gap-2" role="alert">
        <i class="fa-solid fa-check-circle"></i>
        <span>@TempData["Success"]</span>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
}

<div class="branch-summary">
    <div class="branch-summary__card">
        <div class="branch-summary__value">@Model.TotalCount</div>
        <div class="branch-summary__label">Total Branches</div>
    </div>
    <div class="branch-summary__card branch-summary__card--active">
        <div class="branch-summary__value">@Model.ActiveCount</div>
        <div class="branch-summary__label">Active</div>
    </div>
    <div class="branch-summary__card branch-summary__card--inactive">
        <div class="branch-summary__value">@Model.InactiveCount</div>
        <div class="branch-summary__label">Inactive</div>
    </div>
</div>

<div class="content-section">
    <div class="content-section__header">
        <div class="content-section__title">All Branches</div>
    </div>

    @if (Model.Branches.Count == 0)
    {
        <div class="d-flex flex-column align-items-center justify-content-center py-8 text-center">
            <i class="fa-solid fa-building" style="font-size: 3rem; color: var(--text-muted); margin-bottom: var(--space-4);"></i>
            <h5 style="color: var(--text-primary); margin-bottom: var(--space-1);">No branches yet</h5>
            <p style="color: var(--text-muted); margin-bottom: var(--space-4);">Create your first branch to get started</p>
            <a asp-action="Create" class="btn btn-primary">
                <i class="fa-solid fa-plus"></i>
                <span>Create Branch</span>
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-enterprise">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Branch Name</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var branch in Model.Branches)
                    {
                        <tr>
                            <td class="text-muted">@branch.Id</td>
                            <td class="fw-500">@branch.BranchName</td>
                            <td>
                                @if (branch.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-ghost btn-icon" title="Edit" disabled>
                                    <i class="fa-solid fa-pen"></i>
                                </button>
                                <button class="btn btn-sm btn-ghost btn-icon" title="Delete" disabled>
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
