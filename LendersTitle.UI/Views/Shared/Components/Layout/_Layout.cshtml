<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LendersTitle.UI</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/LendersTitle.UI.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/layout/navbar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/components/sidebar.css" asp-append-version="true" />
    <script>
        (function () {
            var theme;
            try { theme = localStorage.getItem('app-theme'); } catch (e) {}
            if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.setAttribute('data-bs-theme', 'dark');
            }
        })();
    </script>
</head>
<body>
    <div class="app-wrapper d-flex min-vh-100">
        @await Html.PartialAsync("Components/Layout/_Sidebar")

        <div class="app-main d-flex flex-column flex-grow-1">
            @await Html.PartialAsync("Components/Layout/_Navbar")

            <div class="app-content flex-grow-1 p-3 p-lg-4">
                <main role="main">
                    @RenderBody()
                </main>
            </div>

            @await Html.PartialAsync("Components/Layout/_Footer")
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/assets/js/core/theme-toggle.js" asp-append-version="true"></script>
    <script src="~/assets/js/core/sidebar.js" asp-append-version="true"></script>
    <script src="~/assets/js/core/app.js" asp-append-version="true"></script>
    <script src="~/assets/js/core/ajax.js" asp-append-version="true"></script>
    <script src="~/assets/js/core/auth.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
