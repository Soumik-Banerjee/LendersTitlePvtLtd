<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LendersTitle.UI</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/LendersTitle.UI.styles.css" asp-append-version="true" />
    <style>
        .app-wrapper {
            min-height: 100vh;
        }
        .app-main {
            min-width: 0;
        }

        /* ── Sidebar ── */
        .sidebar {
            width: 260px;
            height: 100vh;
            position: sticky;
            top: 0;
            flex-shrink: 0;
            background: var(--bs-body-bg);
            transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            overflow-x: hidden;
        }
        .sidebar__brand {
            flex-shrink: 0;
            transition: padding 0.3s ease;
        }
        .sidebar__logo {
            width: 32px;
            height: 32px;
            flex-shrink: 0;
        }
        .sidebar__brand-text {
            font-size: 1rem;
            white-space: nowrap;
        }
        .sidebar__search {
            flex-shrink: 0;
        }
        .sidebar__search .search-icon {
            color: var(--bs-secondary-color);
            font-size: 0.75rem;
        }
        .sidebar__search-input {
            font-size: 0.8125rem;
        }
        .sidebar__search-clear {
            font-size: 0.8125rem;
            cursor: pointer;
        }
        .sidebar__body {
            scrollbar-width: thin;
        }
        .sidebar__section-title {
            font-size: 0.6875rem;
            font-weight: 600;
            color: var(--bs-secondary-color);
            letter-spacing: 0.05em;
            padding: 0.5rem 0.5rem 0.25rem;
        }
        .sidebar__item,
        .sidebar__item-link {
            color: inherit;
            font-size: 0.875rem;
            transition: padding 0.3s ease;
        }
        .sidebar__item-link {
            font-size: 0.8125rem;
        }
        .sidebar__item-icon {
            width: 20px;
            text-align: center;
        }
        .sidebar__item--has-children {
            cursor: pointer;
            font-size: 0.875rem;
        }
        .sidebar__item-badge {
            font-size: 0.625rem;
        }
        .sidebar__item-arrow i {
            font-size: 0.625rem;
        }
        .sidebar__submenu {
            overflow: hidden;
            max-height: 0;
            transition: max-height 0.25s ease;
        }
        .sidebar__submenu.open {
            max-height: 500px;
        }
        .sidebar__item--has-children .sidebar__item-arrow i {
            transition: transform 0.2s ease;
        }
        .sidebar__item--has-children.open .sidebar__item-arrow i {
            transform: rotate(90deg);
        }
        .sidebar__footer {
            flex-shrink: 0;
            transition: padding 0.3s ease;
        }
        .sidebar__footer-avatar {
            width: 32px;
            height: 32px;
            background: var(--bs-primary);
            color: #fff;
            font-size: 0.75rem;
            font-weight: 600;
        }
        .sidebar__footer-info {
            line-height: 1.2;
        }
        .sidebar__footer-name {
            font-size: 0.8125rem;
            font-weight: 600;
        }
        .sidebar__footer-role {
            font-size: 0.6875rem;
            color: var(--bs-secondary-color);
        }
        .sidebar__logout-btn {
            color: var(--bs-secondary-color);
        }
        .sidebar__collapse-btn {
            flex-shrink: 0;
            border-radius: 0;
            color: var(--bs-secondary-color);
            padding: 0.625rem 0;
            cursor: pointer;
        }
        .sidebar__collapse-btn i {
            font-size: 0.75rem;
            transition: transform 0.3s ease;
        }

        /* ── Sidebar collapsed states ── */
        .sidebar.collapsed {
            width: 60px;
        }
        .sidebar.collapsed .sidebar__brand-text,
        .sidebar.collapsed .sidebar__search,
        .sidebar.collapsed .sidebar__section-title,
        .sidebar.collapsed .sidebar__item-text,
        .sidebar.collapsed .sidebar__item-badge,
        .sidebar.collapsed .sidebar__item-arrow,
        .sidebar.collapsed .sidebar__footer-info,
        .sidebar.collapsed .sidebar__logout-btn {
            display: none !important;
        }
        .sidebar.collapsed .sidebar__brand {
            justify-content: center;
            padding: 1rem 0.25rem !important;
        }
        .sidebar.collapsed .sidebar__item {
            justify-content: center;
            padding: 0.5rem !important;
        }
        .sidebar.collapsed .sidebar__item-icon {
            width: auto !important;
            margin: 0;
        }
        .sidebar.collapsed .sidebar__submenu {
            display: none !important;
        }
        .sidebar.collapsed .sidebar__footer {
            justify-content: center;
            padding: 0.5rem !important;
        }
        .sidebar.collapsed .sidebar__collapse-btn i {
            transform: rotate(180deg);
        }

        /* ── Navbar ── */
        .navbar-top {
            flex-shrink: 0;
        }
        .navbar-top .btn-link {
            color: inherit;
        }
        .navbar-top .breadcrumb-chevron {
            color: var(--bs-secondary-color);
            font-size: 0.625rem;
        }
        .navbar-top .breadcrumb-current {
            color: var(--bs-secondary-color);
            font-size: 0.875rem;
        }
        .navbar-top .search-wrapper {
            max-width: 320px;
        }
        .navbar-top .search-icon {
            color: var(--bs-secondary-color);
            font-size: 0.8125rem;
        }
        .navbar-top .search-input {
            font-size: 0.8125rem;
        }
        .navbar-top .search-shortcut {
            font-size: 0.6875rem;
            color: var(--bs-secondary-color);
        }
        .navbar-top .notification-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--bs-danger);
        }
        .navbar-top .avatar-sm {
            width: 32px;
            height: 32px;
            background: var(--bs-primary);
            color: #fff;
            font-size: 0.75rem;
            font-weight: 600;
        }
        .navbar-top .avatar-lg {
            width: 40px;
            height: 40px;
            background: var(--bs-primary);
            color: #fff;
            font-size: 0.875rem;
            font-weight: 600;
        }
        .navbar-top .profile-info {
            line-height: 1.2;
        }
        .navbar-top .profile-name {
            font-size: 0.8125rem;
            font-weight: 600;
        }
        .navbar-top .profile-role {
            font-size: 0.6875rem;
            color: var(--bs-secondary-color);
        }
        .navbar-top .profile-caret {
            font-size: 0.625rem;
            color: var(--bs-secondary-color);
        }
        .navbar-top .dropdown-menu-custom {
            min-width: 240px;
        }
        .navbar-top .dropdown-name {
            font-weight: 600;
            font-size: 0.875rem;
        }
        .navbar-top .dropdown-email {
            font-size: 0.75rem;
            color: var(--bs-secondary-color);
        }

        /* ── Mobile sidebar ── */
        @@media (max-width: 991.98px) {
            .sidebar {
                position: fixed;
                top: 0;
                left: 0;
                bottom: 0;
                z-index: 1050;
                transform: translateX(-100%);
            }
            .sidebar.open {
                transform: translateX(0);
                box-shadow: 4px 0 24px rgba(0,0,0,0.15);
            }
            .sidebar-backdrop {
                display: none;
                position: fixed;
                inset: 0;
                z-index: 1049;
                background: rgba(0,0,0,0.5);
            }
            .sidebar-backdrop.open {
                display: block;
            }
        }
    </style>
    <script>
        (function () {
            var theme;
            try { theme = localStorage.getItem('app-theme'); } catch (e) {}
            if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.setAttribute('data-bs-theme', 'dark');
            }
        })();
    </script>
</head>
<body>
    <div class="app-wrapper d-flex">
        @await Html.PartialAsync("Components/Layout/_Sidebar")

        <div class="app-main d-flex flex-column flex-grow-1">
            @await Html.PartialAsync("Components/Layout/_Navbar")

            <div class="app-content flex-grow-1 p-3 p-lg-4">
                <main role="main">
                    @RenderBody()
                </main>
            </div>

            @await Html.PartialAsync("Components/Layout/_Footer")
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/assets/js/core/theme-toggle.js" asp-append-version="true"></script>
    <script src="~/assets/js/core/sidebar.js" asp-append-version="true"></script>
    <script src="~/assets/js/core/app.js" asp-append-version="true"></script>
    <script src="~/assets/js/core/ajax.js" asp-append-version="true"></script>
    <script src="~/assets/js/core/auth.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
