@using System.Security.Claims
@{
    var fullName = User.FindFirst("FullName")?.Value ?? "User";
    var role = User.FindFirst(ClaimTypes.Role)?.Value ?? "Employee";
    var initials = fullName.Length > 0
        ? string.Concat(fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(s => s[0])).ToUpper()[..Math.Min(2, fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Length)]
        : "U";
}
@* Sidebar Backdrop (mobile/tablet overlay) *@
<div class="sidebar-backdrop" aria-hidden="true"></div>

@* Sidebar *@
<aside class="sidebar" aria-label="Main navigation">
    @* ── Brand / Logo Area ─────────────────────────────────────────── *@
    <div class="sidebar__brand">
        <img src="~/favicon.ico" alt="LendersTitle" class="sidebar__logo" />
        <span class="sidebar__brand-text">LendersTitle</span>
        <button class="sidebar__collapse-btn" type="button" title="Collapse sidebar" aria-label="Collapse sidebar">
            <i class="fa-solid fa-chevron-left"></i>
        </button>
    </div>

    @* ── Sidebar Search ─────────────────────────────────────────────── *@
    <div class="sidebar__search">
        <span class="sidebar__search-icon"><i class="fa-solid fa-magnifying-glass"></i></span>
        <input type="text" class="sidebar__search-input" placeholder="Search menu..." aria-label="Search navigation" autocomplete="off">
        <span class="sidebar__search-clear" role="button" aria-label="Clear search">&times;</span>
    </div>

    @* ── Navigation Body (scrollable) ──────────────────────────────── *@
    <nav class="sidebar__body">

        @* ── Dashboard ── *@
        <div class="sidebar__section">
            <span class="sidebar__section-title">Main</span>
            <a asp-controller="Home" asp-action="Index" class="sidebar__item" data-tooltip="Dashboard">
                <span class="sidebar__item-icon"><i class="fa-solid fa-chart-pie"></i></span>
                <span class="sidebar__item-text">Dashboard</span>
            </a>
        </div>

        @* ── Branch Management ── *@
        <div class="sidebar__section">
            <span class="sidebar__section-title">Branch Management</span>

            <div class="sidebar__item sidebar__item--has-children" data-tooltip="Branch Management">
                <span class="sidebar__item-icon"><i class="fa-solid fa-building"></i></span>
                <span class="sidebar__item-text">Branch Management</span>
                <span class="sidebar__item-badge sidebar__item-badge--info">2</span>
                <span class="sidebar__item-arrow"><i class="fa-solid fa-chevron-right"></i></span>
            </div>
            <ul class="sidebar__submenu">
                <li>
                    <a asp-controller="BranchMaster" asp-action="Index" class="sidebar__item sidebar__item-link" data-tooltip="Branch List">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-list"></i></span>
                        <span class="sidebar__item-text">Branch List</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="BranchMaster" asp-action="Create" class="sidebar__item sidebar__item-link" data-tooltip="Create Branch">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-plus"></i></span>
                        <span class="sidebar__item-text">Create Branch</span>
                    </a>
                </li>
            </ul>
        </div>

        @* ── Attendance ── *@
        <div class="sidebar__section">
            <span class="sidebar__section-title">Attendance</span>

            <div class="sidebar__item sidebar__item--has-children" data-tooltip="Attendance">
                <span class="sidebar__item-icon"><i class="fa-solid fa-calendar-days"></i></span>
                <span class="sidebar__item-text">Attendance</span>
                <span class="sidebar__item-arrow"><i class="fa-solid fa-chevron-right"></i></span>
            </div>
            <ul class="sidebar__submenu">
                <li>
                    <a asp-controller="Attendance" asp-action="CheckIn" class="sidebar__item sidebar__item-link" data-tooltip="Check In">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-calendar-check"></i></span>
                        <span class="sidebar__item-text">Check In</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Attendance" asp-action="History" class="sidebar__item sidebar__item-link" data-tooltip="Attendance History">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-clock"></i></span>
                        <span class="sidebar__item-text">Attendance History</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Attendance" asp-action="Reports" class="sidebar__item sidebar__item-link" data-tooltip="Attendance Reports">
                        <span class="sidebar__item-icon"><i class="fa-solid fa-chart-bar"></i></span>
                        <span class="sidebar__item-text">Attendance Reports</span>
                    </a>
                </li>
            </ul>
        </div>

        @* ── Employee ── *@
        <div class="sidebar__section">
            <span class="sidebar__section-title">Employee</span>

            <div class="sidebar__item sidebar__item--has-children" data-tooltip="Employee">
                <span class="sidebar__item-icon"><i class="fa-solid fa-users"></i></span>
                <span class="sidebar__item-text">Employee</span>
                <span class="sidebar__item-arrow"><i class="fa-solid fa-chevron-right"></i></span>
            </div>
            <ul class="sidebar__submenu">
                <li>
                    <a asp-controller="Employee" asp-action="Index" class="sidebar__item sidebar__item-link" data-tooltip="Employee List">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-list"></i></span>
                        <span class="sidebar__item-text">Employee List</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Employee" asp-action="Departments" class="sidebar__item sidebar__item-link" data-tooltip="Departments">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-building"></i></span>
                        <span class="sidebar__item-text">Departments</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Employee" asp-action="Designations" class="sidebar__item sidebar__item-link" data-tooltip="Designations">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-user-tag"></i></span>
                        <span class="sidebar__item-text">Designations</span>
                    </a>
                </li>
            </ul>
        </div>

        @* ── Loan Management ── *@
        <div class="sidebar__section">
            <span class="sidebar__section-title">Loan Management</span>

            <div class="sidebar__item sidebar__item--has-children" data-tooltip="Loan Management">
                <span class="sidebar__item-icon"><i class="fa-solid fa-hand-holding-dollar"></i></span>
                <span class="sidebar__item-text">Loan Management</span>
                <span class="sidebar__item-badge">12</span>
                <span class="sidebar__item-arrow"><i class="fa-solid fa-chevron-right"></i></span>
            </div>
            <ul class="sidebar__submenu">
                <li>
                    <a asp-controller="Loan" asp-action="Application" class="sidebar__item sidebar__item-link" data-tooltip="Loan Application">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-file-lines"></i></span>
                        <span class="sidebar__item-text">Loan Application</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Loan" asp-action="Approval" class="sidebar__item sidebar__item-link" data-tooltip="Loan Approval">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-circle-check"></i></span>
                        <span class="sidebar__item-text">Loan Approval</span>
                        <span class="sidebar__item-badge sidebar__item-badge--warning">5</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Loan" asp-action="Disbursement" class="sidebar__item sidebar__item-link" data-tooltip="Disbursement">
                        <span class="sidebar__item-icon"><i class="fa-solid fa-money-bill-transfer"></i></span>
                        <span class="sidebar__item-text">Disbursement</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Loan" asp-action="EMICollection" class="sidebar__item sidebar__item-link" data-tooltip="EMI Collection">
                        <span class="sidebar__item-icon"><i class="fa-solid fa-hand-holding-dollar"></i></span>
                        <span class="sidebar__item-text">EMI Collection</span>
                    </a>
                </li>
            </ul>
        </div>

        @* ── Reports ── *@
        <div class="sidebar__section">
            <span class="sidebar__section-title">Reports</span>

            <div class="sidebar__item sidebar__item--has-children" data-tooltip="Reports">
                <span class="sidebar__item-icon"><i class="fa-solid fa-chart-simple"></i></span>
                <span class="sidebar__item-text">Reports</span>
                <span class="sidebar__item-arrow"><i class="fa-solid fa-chevron-right"></i></span>
            </div>
            <ul class="sidebar__submenu">
                <li>
                    <a asp-controller="Reports" asp-action="Attendance" class="sidebar__item sidebar__item-link" data-tooltip="Attendance Reports">
                        <span class="sidebar__item-icon"><i class="fa-solid fa-user-clock"></i></span>
                        <span class="sidebar__item-text">Attendance Reports</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Reports" asp-action="Loan" class="sidebar__item sidebar__item-link" data-tooltip="Loan Reports">
                        <span class="sidebar__item-icon"><i class="fa-solid fa-file-invoice-dollar"></i></span>
                        <span class="sidebar__item-text">Loan Reports</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Reports" asp-action="Employee" class="sidebar__item sidebar__item-link" data-tooltip="Employee Reports">
                        <span class="sidebar__item-icon"><i class="fa-solid fa-users-gear"></i></span>
                        <span class="sidebar__item-text">Employee Reports</span>
                    </a>
                </li>
            </ul>
        </div>

        @* ── Settings ── *@
        <div class="sidebar__section">
            <span class="sidebar__section-title">Settings</span>

            <div class="sidebar__item sidebar__item--has-children" data-tooltip="Settings">
                <span class="sidebar__item-icon"><i class="fa-solid fa-gear"></i></span>
                <span class="sidebar__item-text">Settings</span>
                <span class="sidebar__item-arrow"><i class="fa-solid fa-chevron-right"></i></span>
            </div>
            <ul class="sidebar__submenu">
                <li>
                    <a asp-controller="Settings" asp-action="Users" class="sidebar__item sidebar__item-link" data-tooltip="Users">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-user"></i></span>
                        <span class="sidebar__item-text">Users</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Settings" asp-action="Roles" class="sidebar__item sidebar__item-link" data-tooltip="Roles">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-shield"></i></span>
                        <span class="sidebar__item-text">Roles</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Settings" asp-action="Permissions" class="sidebar__item sidebar__item-link" data-tooltip="Permissions">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-lock"></i></span>
                        <span class="sidebar__item-text">Permissions</span>
                    </a>
                </li>
            </ul>
        </div>

    </nav>

    @* ── Sidebar Footer: User Profile + Logout ──────────────────────── *@
    <div class="sidebar__footer">
        <div class="sidebar__footer-user">
            <div class="sidebar__footer-avatar">
                <span>@initials</span>
            </div>
            <div class="sidebar__footer-info">
                <span class="sidebar__footer-name">@fullName</span>
                <span class="sidebar__footer-role">@role</span>
            </div>
        </div>
        <a asp-controller="Login" asp-action="Logout" class="sidebar__logout-btn" title="Logout" aria-label="Logout">
            <i class="fa-solid fa-right-from-bracket"></i>
        </a>
    </div>
</aside>
