                        </li>
                        <li>
                            <a href="#"
                               class="sidebar__sub-link @(IsActive("/loan/list") ? "active" : "")">
                                Loan List
                            </a>
                        </li>
                        <li>
                            <a href="#"
                               class="sidebar__sub-link @(IsActive("/loan/approval") ? "active" : "")">
                                Loan Approval
                            </a>
                        </li>
                        <li>
                            <a href="#"
                               class="sidebar__sub-link @(IsActive("/loan/reports") ? "active" : "")">
                                Loan Reports
                            </a>
                        </li>
                    </ul>
                </div>
