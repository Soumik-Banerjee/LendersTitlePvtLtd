                </button>
                <div class="collapse @(IsParentActive(new[]{"/loan"}) ? "show" : "")" id="subLoan">
                    <ul class="sidebar__sub">
                        <li>
                            <a href="#"
                               class="sidebar__sub-link @(IsActive("/loan/new") ? "active" : "")">
                                New Loan
