@using System.Security.Claims
@{
    var fullName = User.FindFirst("FullName")?.Value ?? "User";
    var role = User.FindFirst(ClaimTypes.Role)?.Value ?? "Employee";
    var initials = fullName.Length > 0
        ? string.Concat(fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Select(s => s[0])).ToUpper()[..Math.Min(2, fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Length)]
        : "U";
    var currentPath = Context.Request.Path.ToString().ToLowerInvariant();
}

@functions {
    bool IsActive(string path)
    {
        var current = System.Text.RegularExpressions.Regex.Replace(Context.Request.Path.ToString(), "/$", "");
        var target = System.Text.RegularExpressions.Regex.Replace(path, "/$", "");
        return current.Equals(target, StringComparison.OrdinalIgnoreCase) ||
               current.StartsWith(target + "/", StringComparison.OrdinalIgnoreCase);
    }

    bool IsParentActive(string[] paths)
    {
        var current = Context.Request.Path.ToString().ToLowerInvariant();
        foreach (var p in paths)
        {
            if (current.StartsWith(p.ToLowerInvariant()))
                return true;
        }
        return false;
    }
}

@* =========================================================================
   DESKTOP SIDEBAR (>= 992px)
   ========================================================================= *@
<aside class="sidebar sidebar-fixed d-none d-lg-flex" id="sidebarDesktop"
       aria-label="Main navigation">

    @* Header: Logo + Toggle *@
    <div class="sidebar__header">
        <a href="@Url.Action("Index", "Home")" class="sidebar__brand">
            <span class="sidebar__brand-logo">
                <img src="~/favicon.ico" alt="Lenders Title" class="sidebar__brand-img" />
            </span>
            <span class="sidebar__brand-text">Lenders Title</span>
        </a>

        <button type="button"
                class="sidebar__toggle-btn"
                id="sidebarToggle"
                aria-label="Toggle sidebar"
                title="Toggle sidebar (Ctrl+B)">
            <i class="fa-solid fa-chevron-left"></i>
        </button>
    </div>

    @* Search *@
    <div class="sidebar__search">
        <div class="sidebar__search-wrapper">
            <i class="fa-solid fa-search sidebar__search-icon"></i>
            <input type="search"
                   class="form-control sidebar__search-input"
                   placeholder="Search menu..."
                   aria-label="Search menu"
                   autocomplete="off" />
        </div>
    </div>

    @* Scrollable navigation *@
    <nav class="sidebar__body" aria-label="Sidebar navigation">
        <ul class="sidebar__nav">

            @* -- Dashboard -- *@
            <li class="sidebar__section">Main</li>

            <li class="sidebar__item">
                <a href="@Url.Action("Index", "Home")"
                   class="sidebar__link @(IsActive("/home") ? "active" : "")"
                   aria-current="@(IsActive("/home") ? "page" : null)">
                    <span class="sidebar__icon"><i class="fa-solid fa-house"></i></span>
                    <span class="sidebar__label">Dashboard</span>
                </a>
            </li>

            @* -- Master Data -- *@
            <li class="sidebar__section">Master Data</li>

            <li class="sidebar__item">
                <a href="@Url.Action("Index", "BranchMaster")"
                   class="sidebar__link @(IsActive("/branchmaster") ? "active" : "")"
                   aria-current="@(IsActive("/branchmaster") ? "page" : null)">
                    <span class="sidebar__icon"><i class="fa-solid fa-building"></i></span>
                    <span class="sidebar__label">Branches</span>
                </a>
            </li>

            <li class="sidebar__item sidebar__item--has-sub">
                <button type="button"
                        class="sidebar__link sidebar__link--sub-toggle"
                        data-bs-toggle="collapse"
                        data-bs-target="#subEmployee"
                        aria-expanded="@(IsParentActive(new[]{"/employee"}) ? "true" : "false")"
                        aria-controls="subEmployee">
                    <span class="sidebar__icon"><i class="fa-solid fa-users"></i></span>
                    <span class="sidebar__label">Employees</span>
                    <i class="fa-solid fa-chevron-down sidebar__arrow"></i>
                </button>
                <div class="collapse @(IsParentActive(new[]{"/employee"}) ? "show" : "")" id="subEmployee">
                    <ul class="sidebar__sub">
                        <li>
                            <a href="#"
                               class="sidebar__sub-link @(IsActive("/employee") ? "active" : "")">
                                Employee List
                            </a>
                        </li>
                        <li>
                            <a href="#"
                               class="sidebar__sub-link @(IsActive("/employee/create") ? "active" : "")">
                                Add Employee
                            </a>
                        </li>
                    </ul>
                </div>
            </li>

            <li class="sidebar__item">
                <a href="#"
                   class="sidebar__link">
                    <span class="sidebar__icon"><i class="fa-solid fa-user-tie"></i></span>
                    <span class="sidebar__label">Users</span>
                </a>
            </li>

            @* -- Operations -- *@
            <li class="sidebar__section">Operations</li>

            <li class="sidebar__item sidebar__item--has-sub">
                <button type="button"
                        class="sidebar__link sidebar__link--sub-toggle"
                        data-bs-toggle="collapse"
                        data-bs-target="#subLoan"
                        aria-expanded="@(IsParentActive(new[]{"/loan"}) ? "true" : "false")"
                        aria-controls="subLoan">
