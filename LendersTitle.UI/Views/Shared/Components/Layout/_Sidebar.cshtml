@* Sidebar Backdrop (mobile) *@
<div class="sidebar-backdrop"></div>

@* Sidebar *@
<aside class="sidebar">
    <div class="sidebar__brand">
        <img src="~/favicon.ico" alt="Logo" class="sidebar__logo" />
        <span class="sidebar__brand-text">LendersTitle</span>
    </div>

    <nav class="sidebar__nav">
        @* Dashboard *@
        <div class="sidebar__section">
            <span class="sidebar__section-title">Main</span>
            <a asp-controller="Home" asp-action="Index" class="sidebar__item">
                <span class="sidebar__item-icon"><i class="fa-solid fa-chart-pie"></i></span>
                <span class="sidebar__item-text">Dashboard</span>
            </a>
        </div>

        @* Masters *@
        <div class="sidebar__section">
            <span class="sidebar__section-title">Masters</span>

            <div class="sidebar__item sidebar__item--has-children">
                <span class="sidebar__item-icon"><i class="fa-solid fa-building"></i></span>
                <span class="sidebar__item-text">Branch</span>
                <span class="sidebar__item-badge sidebar__item-badge--info">2</span>
                <span class="sidebar__item-arrow"><i class="fa-solid fa-chevron-right"></i></span>
            </div>
            <ul class="sidebar__submenu">
                <li>
                    <a asp-controller="BranchMaster" asp-action="Index" class="sidebar__item sidebar__item-link" data-tooltip="View Branches">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-list"></i></span>
                        <span class="sidebar__item-text">View Branches</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="BranchMaster" asp-action="Create" class="sidebar__item sidebar__item-link" data-tooltip="Add Branch">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-plus"></i></span>
                        <span class="sidebar__item-text">Add Branch</span>
                    </a>
                </li>
            </ul>

            <div class="sidebar__item sidebar__item--has-children">
                <span class="sidebar__item-icon"><i class="fa-solid fa-users"></i></span>
                <span class="sidebar__item-text">Employees</span>
                <span class="sidebar__item-arrow"><i class="fa-solid fa-chevron-right"></i></span>
            </div>
            <ul class="sidebar__submenu">
                <li>
                    <a href="#" class="sidebar__item sidebar__item-link">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-list"></i></span>
                        <span class="sidebar__item-text">All Employees</span>
                    </a>
                </li>
                <li>
                    <a href="#" class="sidebar__item sidebar__item-link">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-plus"></i></span>
                        <span class="sidebar__item-text">Add Employee</span>
                    </a>
                </li>
                <li>
                    <a href="#" class="sidebar__item sidebar__item-link">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-user"></i></span>
                        <span class="sidebar__item-text">Departments</span>
                    </a>
                </li>
            </ul>

            <div class="sidebar__item sidebar__item--has-children">
                <span class="sidebar__item-icon"><i class="fa-solid fa-user-tie"></i></span>
                <span class="sidebar__item-text">Customers</span>
                <span class="sidebar__item-arrow"><i class="fa-solid fa-chevron-right"></i></span>
            </div>
            <ul class="sidebar__submenu">
                <li>
                    <a href="#" class="sidebar__item sidebar__item-link">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-list"></i></span>
                        <span class="sidebar__item-text">All Customers</span>
                    </a>
                </li>
                <li>
                    <a href="#" class="sidebar__item sidebar__item-link">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-plus"></i></span>
                        <span class="sidebar__item-text">Add Customer</span>
                    </a>
                </li>
            </ul>
        </div>

        @* Operations *@
        <div class="sidebar__section">
            <span class="sidebar__section-title">Operations</span>

            <div class="sidebar__item sidebar__item--has-children">
                <span class="sidebar__item-icon"><i class="fa-solid fa-hand-holding-dollar"></i></span>
                <span class="sidebar__item-text">Loan Applications</span>
                <span class="sidebar__item-badge">12</span>
                <span class="sidebar__item-arrow"><i class="fa-solid fa-chevron-right"></i></span>
            </div>
            <ul class="sidebar__submenu">
                <li>
                    <a href="#" class="sidebar__item sidebar__item-link">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-list"></i></span>
                        <span class="sidebar__item-text">All Applications</span>
                    </a>
                </li>
                <li>
                    <a href="#" class="sidebar__item sidebar__item-link">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-plus"></i></span>
                        <span class="sidebar__item-text">New Application</span>
                    </a>
                </li>
                <li>
                    <a href="#" class="sidebar__item sidebar__item-link">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-clock"></i></span>
                        <span class="sidebar__item-text">Pending Approvals</span>
                        <span class="sidebar__item-badge sidebar__item-badge--warning">5</span>
                    </a>
                </li>
            </ul>

            <a href="#" class="sidebar__item">
                <span class="sidebar__item-icon"><i class="fa-solid fa-check-double"></i></span>
                <span class="sidebar__item-text">Approvals</span>
                <span class="sidebar__item-badge sidebar__item-badge--warning">8</span>
            </a>
        </div>

        @* Attendance *@
        <div class="sidebar__section">
            <span class="sidebar__section-title">Attendance</span>

            <div class="sidebar__item sidebar__item--has-children">
                <span class="sidebar__item-icon"><i class="fa-solid fa-calendar-days"></i></span>
                <span class="sidebar__item-text">Attendance</span>
                <span class="sidebar__item-arrow"><i class="fa-solid fa-chevron-right"></i></span>
            </div>
            <ul class="sidebar__submenu">
                <li>
                    <a href="#" class="sidebar__item sidebar__item-link">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-calendar-check"></i></span>
                        <span class="sidebar__item-text">Mark Attendance</span>
                    </a>
                </li>
                <li>
                    <a href="#" class="sidebar__item sidebar__item-link">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-list"></i></span>
                        <span class="sidebar__item-text">Attendance Report</span>
                    </a>
                </li>
                <li>
                    <a href="#" class="sidebar__item sidebar__item-link">
                        <span class="sidebar__item-icon"><i class="fa-regular fa-pen-to-square"></i></span>
                        <span class="sidebar__item-text">Correction Requests</span>
                    </a>
                </li>
            </ul>

            <a href="#" class="sidebar__item">
                <span class="sidebar__item-icon"><i class="fa-solid fa-clock"></i></span>
                <span class="sidebar__item-text">Shift Management</span>
            </a>

            <a href="#" class="sidebar__item">
                <span class="sidebar__item-icon"><i class="fa-solid fa-gift"></i></span>
                <span class="sidebar__item-text">Leave Requests</span>
                <span class="sidebar__item-badge sidebar__item-badge--warning">3</span>
            </a>
        </div>

        @* Reports *@
        <div class="sidebar__section">
            <span class="sidebar__section-title">Reports</span>
            <a href="#" class="sidebar__item">
                <span class="sidebar__item-icon"><i class="fa-solid fa-chart-bar"></i></span>
                <span class="sidebar__item-text">Reports</span>
            </a>
            <a href="#" class="sidebar__item">
                <span class="sidebar__item-icon"><i class="fa-solid fa-file-export"></i></span>
                <span class="sidebar__item-text">Exports</span>
            </a>
        </div>

        @* System *@
        <div class="sidebar__section">
            <span class="sidebar__section-title">System</span>
            <a href="#" class="sidebar__item">
                <span class="sidebar__item-icon"><i class="fa-solid fa-gear"></i></span>
                <span class="sidebar__item-text">Settings</span>
            </a>
            <a href="#" class="sidebar__item">
                <span class="sidebar__item-icon"><i class="fa-solid fa-shield-halved"></i></span>
                <span class="sidebar__item-text">User Management</span>
            </a>
            <a href="#" class="sidebar__item">
                <span class="sidebar__item-icon"><i class="fa-solid fa-calendar"></i></span>
                <span class="sidebar__item-text">Holidays</span>
            </a>
        </div>
    </nav>

    @* Sidebar Footer *@
    <div class="sidebar__footer">
        <div class="sidebar__footer-user">
            <div class="sidebar__footer-avatar">
                <i class="fa-solid fa-user"></i>
            </div>
            <div class="sidebar__footer-info">
                <span class="sidebar__footer-name">Admin User</span>
                <span class="sidebar__footer-role">Administrator</span>
            </div>
        </div>
    @*     <button class="sidebar__collapse-btn" title="Toggle Sidebar" aria-label="Toggle Sidebar">
            <i class="fa-solid fa-chevron-left"></i>
        </button> *@
    </div>
</aside>
