            <li class="sidebar__item sidebar__item--has-sub">
                <button type="button"
                        class="sidebar__link sidebar__link--sub-toggle"
                        data-bs-toggle="collapse"
                        data-bs-target="#subAttendance"
                        aria-expanded="@(IsParentActive(new[]{"/attendance"}) ? "true" : "false")"
                        aria-controls="subAttendance">
                    <span class="sidebar__icon"><i class="fa-solid fa-clock"></i></span>
                    <span class="sidebar__label">Attendance</span>
                    <i class="fa-solid fa-chevron-down sidebar__arrow"></i>
                </button>
                <div class="collapse @(IsParentActive(new[]{"/attendance"}) ? "show" : "")" id="subAttendance">
                    <ul class="sidebar__sub">
                        <li>
                            <a href="#"
                               class="sidebar__sub-link @(IsActive("/attendance/daily") ? "active" : "")">
                                Daily Log
                            </a>
                        </li>
                        <li>
                            <a href="#"
                               class="sidebar__sub-link @(IsActive("/attendance/report") ? "active" : "")">
                                Reports
                            </a>
                        </li>
                    </ul>
                </div>
            </li>

            @* -- Reports -- *@
            <li class="sidebar__section">Reports</li>

            <li class="sidebar__item">
                <a href="#"
                   class="sidebar__link">
                    <span class="sidebar__icon"><i class="fa-solid fa-chart-pie"></i></span>
                    <span class="sidebar__label">Analytics</span>
                </a>
            </li>

            <li class="sidebar__item">
                <a href="#"
                   class="sidebar__link">
                    <span class="sidebar__icon"><i class="fa-solid fa-file-lines"></i></span>
                    <span class="sidebar__label">Reports</span>
                </a>
            </li>

            @* -- Administration -- *@
            <li class="sidebar__section">Administration</li>

            <li class="sidebar__item">
                <a href="#"
                   class="sidebar__link">
                    <span class="sidebar__icon"><i class="fa-solid fa-gear"></i></span>
                    <span class="sidebar__label">Settings</span>
                </a>
            </li>

            <li class="sidebar__item">
                <a href="#"
                   class="sidebar__link">
                    <span class="sidebar__icon"><i class="fa-solid fa-shield-halved"></i></span>
                    <span class="sidebar__label">Permissions</span>
                </a>
            </li>

            <li class="sidebar__item">
                <a href="#"
                   class="sidebar__link">
                    <span class="sidebar__icon"><i class="fa-solid fa-list-check"></i></span>
                    <span class="sidebar__label">Audit Log</span>
                </a>
            </li>
        </ul>
    </nav>

    @* User Profile *@
    <div class="sidebar__profile">
        <a href="#" class="sidebar__profile-link" title="User profile">
            <div class="sidebar__avatar" aria-hidden="true">
                @initials
            </div>
            <div class="sidebar__profile-info">
                <span class="sidebar__profile-name">@fullName</span>
                <span class="sidebar__profile-role">@role</span>
            </div>
        </a>
        <button type="button"
                class="sidebar__logout"
                data-logout-url="@Url.Action("Logout", "Login")"
                aria-label="Sign out">
            <i class="fa-solid fa-right-from-bracket"></i>
        </button>
    </div>
</aside>

